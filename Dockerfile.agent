FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/mishmesh-agent ./cmd/mishmesh-agent

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/mishmesh-agent /usr/local/bin/mishmesh-agent
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/mishmesh-agent"]
